# --- required ---
OPENAI_API_KEY=
# DATABASE_URL is set by docker-compose; for bare `go run`:
# DATABASE_URL=postgres://thornhill:thornhill@localhost:5432/thornhill?sslmode=disable

# --- hermes (leave HERMES_BASE_URL empty to use the stub worker) ---
# For a loopback-only Hermes API on the same Linux host, use
# docker-compose.host.yml and HERMES_BASE_URL=http://127.0.0.1:8642.
# HERMES_BASE_URL=https://hermes.your-fleet.example
# HERMES_API_KEY=
# HERMES_MODEL=default
# Resource threshold only: after silence, persist the unresolved approval and
# stop its run. This never allows or denies the request.
# APPROVAL_PARK_AFTER=15m

# --- OpenAI-compatible provider ---
# Production default shown below. OPENAI_REALTIME_WS_URL is derived from the
# base unless explicitly overridden. Non-TLS endpoints are accepted only on
# explicit loopback hosts for disposable test providers.
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime

# --- models ---
# REALTIME_MODEL=gpt-realtime-2.1
# REALTIME_VOICE=marin
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy
# SUMMARY_MODEL=gpt-5.5
# TRANSCRIBE_MODEL=gpt-realtime-whisper

# --- session timer ladder ---
# QUIET_AFTER=30s
# PARK_AFTER=10m
# ROLLOVER_AT=57m

# --- server and browser development ---
# LISTEN_ADDR=:8787
# Needed only when using a separate Vite dev origin; comma-separated allow-list.
# ALLOWED_ORIGINS=localhost:5173
# Docker Compose publishes loopback by default. Set to a specific Tailscale IP
# for intentional tailnet access, never 0.0.0.0 on an internet-facing host.
# THORNHILL_BIND_ADDR=127.0.0.1
# LOG_LEVEL=debug
# FAKE_JOB_SECONDS=90
# DAILY_BUDGET_USD=25
# SAFETY_IDENTIFIER=thornhill-admin
