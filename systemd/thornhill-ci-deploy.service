[Unit]
Description=Deploy Thornhill revision proven by successful main CI
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=@ROOT@
Environment=PATH=/usr/local/bin:/usr/bin:/bin:/snap/bin
Environment=DEPLOY_POLL_MODE=1
Environment=QUIET_DEPLOY_DEFERRALS=1
Environment=QUIET_ALREADY_CURRENT=1
ExecStart=@ROOT@/scripts/deploy-passed-main.sh
TimeoutStartSec=20min
